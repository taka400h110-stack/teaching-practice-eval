{
  "name": "webapp",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build --mode client && vite build",
    "db:migrate:local": "npx wrangler d1 migrations apply DB --local",
    "preview": "wrangler pages dev dist --ip 127.0.0.1 --port 8788",
    "deploy": "npm run build && wrangler pages deploy dist",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "test:e2e:smoke": "playwright test tests/e2e/role-ui-audit.onboarded.spec.ts tests/e2e/role-ui-audit.not-onboarded.spec.ts tests/e2e/role-rbac-matrix.spec.ts",
    "test:e2e:export": "playwright test tests/e2e/export-filter-audit.spec.ts",
    "test:e2e:stats:normal": "playwright test tests/e2e/statistics-validity.normal.spec.ts",
    "test:e2e:stats:empty": "playwright test tests/e2e/statistics-validity.empty.spec.ts",
    "test:e2e:optional:stats-malformed": "playwright test tests/e2e/statistics-validity.malformed.spec.ts",
    "test:e2e:optional:mobile": "playwright test tests/e2e/mobile-interaction-audit.spec.ts",
    "test:e2e:optional:provider-health": "playwright test tests/e2e/provider-health-audit.spec.ts",
    "test:ui:audit": "npm run test:e2e:smoke && npm run test:e2e:export && npm run test:e2e:stats:normal && npm run test:e2e:stats:empty",
    "test:ui:audit:optional": "npm run test:e2e:optional:stats-malformed && npm run test:e2e:optional:mobile && npm run test:e2e:optional:provider-health"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.8",
    "@mui/material": "^7.3.8",
    "@tanstack/react-query": "^5.90.21",
    "bcryptjs": "^3.0.3",
    "glob": "^13.0.6",
    "hono": "^4.12.3",
    "mermaid": "^11.13.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "react-transition-group": "^4.4.5",
    "recharts": "^2.15.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260305.0",
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-cloudflare-pages": "^0.4.3",
    "@hono/vite-dev-server": "^0.18.2",
    "@playwright/test": "^1.58.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-react": "^5.1.4",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "wrangler": "^4.4.0"
  }
}
